# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub OAuth (via Supabase)
# Configure in Supabase Dashboard > Authentication > Providers > GitHub

# HMAC secret for card verification signatures
HMAC_SECRET=generate-with-node-e-crypto-randomBytes-64

# GitHub token for OG image generation (service account, no user scope needed)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Public site URL (used for OG images, verify URLs, metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
